{
  "name": "ml4js",
  "version": "0.2.0",
  "description": "A scikit-learn inspired machine learning toolkit for Node.js and TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist coverage tests/.tmp tests/**/*.js tests/**/*.js.map tests/**/*.d.ts tests/**/*.d.ts.map",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "machine-learning",
    "typescript",
    "nodejs",
    "scikit-learn",
    "plotly"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "plotly.js-dist-min": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.27.0",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
